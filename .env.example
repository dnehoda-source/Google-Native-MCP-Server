# ═══════════════════════════════════════════════════════════════
# Google-Native MCP Server v2.0 — Environment Variables
# ═══════════════════════════════════════════════════════════════
# All integrations are OPTIONAL. Unconfigured tools return
# helpful error messages instead of crashing.
# For Cloud Run: use --set-env-vars and --set-secrets.
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED: Google SecOps ─────────────────────────────────
SECOPS_PROJECT_ID=your-project-id
SECOPS_CUSTOMER_ID=your-customer-id
SECOPS_REGION=us

# ─── OPTIONAL: Google Threat Intel / VirusTotal ──────────────
GTI_API_KEY=

# ─── OPTIONAL: Microsoft Graph (O365 Email Purge) ───────────
O365_TENANT_ID=
O365_CLIENT_ID=
O365_CLIENT_SECRET=

# ─── OPTIONAL: Okta (User Suspension) ───────────────────────
OKTA_DOMAIN=your-org.okta.com
OKTA_API_TOKEN=

# ─── OPTIONAL: Azure AD / Entra ID (Session Revocation) ─────
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# ─── OPTIONAL: AWS (IAM Key + STS Session Revocation) ───────
SOAR_AWS_KEY=
SOAR_AWS_SECRET=

# ─── OPTIONAL: CrowdStrike Falcon (Host Isolation) ──────────
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# ─── SERVER ──────────────────────────────────────────────────
PORT=8080
